{
  "id": "azure-devops",
  "name": "Azure DevOps",
  "version": "0.5.0",
  "sdkVersion": 2,
  "description": "Azure DevOps: work items, iterations, teams, velocity, areas, activity, AB# auto-linking",
  "icon": "kanban",
  "tint": "0, 120, 215",
  "instructions": "instructions.md",
  "aiKeywords": [
    "azure devops",
    "ado",
    "work item",
    "workitems",
    "backlog",
    "sprint",
    "iteration",
    "velocity",
    "burndown",
    "team capacity",
    "team",
    "area path",
    "user story",
    "bug",
    "task",
    "feature",
    "epic",
    "standup",
    "retro",
    "retrospective",
    "AB#",
    "ab-reference"
  ],
  "activationConditions": {
    "configKeys": [
      "AzureDevOpsOrg",
      "AzureDevOpsProject",
      "AzureDevOpsPAT"
    ]
  },
  "settings": [],
  "contributions": {
    "routes": "routes.js",
    "nativeSettings": {
      "targetId": "settingsTab-ado"
    },
    "nativeTabs": [
      {
        "tabBtnId": "backlogTabBtn",
        "panelId": "panel-backlog",
        "openable": true
      },
      {
        "tabBtnId": "workitemTabBtn",
        "panelId": "panel-workitem",
        "openable": false
      },
      {
        "tabBtnId": "activityTabBtn",
        "panelId": "panel-activity",
        "openable": false
      }
    ],
    "nativeRightTabs": [
      {
        "tabBtnId": "intelTab-activity",
        "panelId": "ipanel-activity"
      },
      {
        "tabBtnId": "intelTab-team",
        "panelId": "ipanel-team"
      }
    ],
    "leftQuickActions": [
      {
        "id": "ado-new-item",
        "label": "New Work Item",
        "icon": "plus",
        "command": "openCreateModal"
      },
      {
        "id": "ado-my-items",
        "label": "My Items",
        "icon": "user",
        "command": "filterMyItems"
      }
    ],
    "aiActions": [
      {
        "id": "standup-summary",
        "label": "Standup Summary",
        "icon": "message-square",
        "requires": [
          "sprint"
        ],
        "script": "scripts/Get-StandupSummary.ps1",
        "args": "-IterationPath '${sprint}'",
        "analyze": "give me a brief analysis of the standup for \"${sprintName}\". What should we focus on today?"
      },
      {
        "id": "iteration-status",
        "label": "Iteration Status",
        "icon": "bar-chart-2",
        "requires": [
          "sprint"
        ],
        "script": "scripts/Get-SprintStatus.ps1",
        "analyze": "analyze the results. Are we on track for \"${sprintName}\"? Any concerns?"
      },
      {
        "id": "retrospective",
        "label": "Retrospective",
        "icon": "rotate-ccw",
        "script": "scripts/Get-Retrospective.ps1",
        "analyze": "give me a retrospective analysis. What went well? What can we improve?"
      }
    ],
    "commitLinkers": [
      {
        "id": "ab-ref",
        "pattern": "AB#(\\d+)",
        "urlTemplate": "{adoOrgUrl}/_workitems/edit/{1}",
        "note": "Auto-links AB#<id> in commit messages and branch names to the corresponding ADO work item"
      }
    ],
    "workItemProvider": {
      "id": "azure-devops",
      "label": "Azure DevOps",
      "listRoute": "/api/workitems",
      "createRoute": "/api/workitems/create",
      "getRoute": "/api/workitems/:id",
      "updateStateRoute": "/api/workitems/:id/state",
      "commentRoute": "/api/workitems/:id/comments",
      "iterationsRoute": "/api/iterations",
      "teamsRoute": "/api/teams",
      "teamMembersRoute": "/api/team-members",
      "areasRoute": "/api/areas",
      "velocityRoute": "/api/velocity",
      "burndownRoute": "/api/burndown",
      "startWorkingRoute": "/api/start-working"
    },
    "sensitiveKeys": [
      "AzureDevOpsPAT"
    ],
    "imageAuth": [
      {
        "hostnamePattern": "dev.azure.com",
        "authType": "basic-pat",
        "authConfigKey": "AzureDevOpsPAT"
      }
    ]
  }
}
