{
  "id": "azure-devops",
  "name": "Azure DevOps",
  "version": "0.6.1",
  "sdkVersion": 2,
  "description": "Azure DevOps: work items, iterations, teams, velocity, areas, activity, AB# auto-linking",
  "icon": "kanban",
  "tint": "0, 120, 215",
  "instructions": "instructions.md",
  "aiKeywords": [
    "azure devops",
    "ado",
    "work item",
    "workitems",
    "backlog",
    "sprint",
    "iteration",
    "velocity",
    "burndown",
    "team capacity",
    "team",
    "area path",
    "user story",
    "bug",
    "task",
    "feature",
    "epic",
    "standup",
    "retro",
    "retrospective",
    "AB#",
    "ab-reference"
  ],
  "activationConditions": {
    "configKeys": [
      "AzureDevOpsOrg",
      "AzureDevOpsProject",
      "AzureDevOpsPAT"
    ]
  },
  "settings": [],
  "contributions": {
    "routes": "routes.js",
    "configKeys": [
      "AzureDevOpsOrg",
      "AzureDevOpsProject",
      "AzureDevOpsProjects",
      "AzureDevOpsPAT",
      "DefaultTeam",
      "DefaultArea"
    ],
    "sensitiveKeys": [
      "AzureDevOpsPAT"
    ],
    "imageAuth": [
      {
        "hostnamePattern": "dev.azure.com",
        "authType": "basic-pat",
        "authConfigKey": "AzureDevOpsPAT"
      },
      {
        "hostnamePattern": "visualstudio.com",
        "authType": "basic-pat",
        "authConfigKey": "AzureDevOpsPAT"
      }
    ],
    "nativeSettings": {
      "targetId": "settingsTab-ado"
    },
    "centerTabs": [
      {
        "id": "backlog",
        "label": "Backlog",
        "icon": "list-todo",
        "pinned": true,
        "position": 2,
        "claims": { "tabBtnId": "backlogTabBtn", "panelId": "panel-backlog" },
        "openable": true
      },
      {
        "id": "workitem",
        "label": "Work Item",
        "icon": "ticket",
        "popup": true,
        "position": 3,
        "claims": { "tabBtnId": "workitemTabBtn", "panelId": "panel-workitem" }
      },
      {
        "id": "activity",
        "label": "Activity Timeline",
        "icon": "activity",
        "popup": true,
        "position": 5,
        "claims": { "tabBtnId": "activityTabBtn", "panelId": "panel-activity" }
      }
    ],
    "leftQuickActions": [
      {
        "id": "ado-new-item",
        "label": "New Work Item",
        "icon": "plus",
        "command": "openCreateModal"
      },
      {
        "id": "ado-my-items",
        "label": "My Items",
        "icon": "user",
        "command": "filterMyItems"
      }
    ],
    "aiActions": [
      {
        "id": "standup-summary",
        "label": "Standup Summary",
        "icon": "message-square",
        "requires": [
          "sprint"
        ],
        "script": "scripts/Get-StandupSummary.ps1",
        "args": "-IterationPath '${sprint}'",
        "analyze": "give me a brief analysis of the standup for \"${sprintName}\". What should we focus on today?"
      },
      {
        "id": "iteration-status",
        "label": "Iteration Status",
        "icon": "bar-chart-2",
        "requires": [
          "sprint"
        ],
        "script": "scripts/Get-SprintStatus.ps1",
        "analyze": "analyze the results. Are we on track for \"${sprintName}\"? Any concerns?"
      },
      {
        "id": "retrospective",
        "label": "Retrospective",
        "icon": "rotate-ccw",
        "script": "scripts/Get-Retrospective.ps1",
        "analyze": "give me a retrospective analysis. What went well? What can we improve?"
      }
    ],
    "commitLinkers": [
      {
        "id": "ab-ref",
        "pattern": "AB#(\\d+)",
        "urlTemplate": "{adoOrgUrl}/_workitems/edit/{1}",
        "note": "Auto-links AB#<id> in commit messages and branch names to the corresponding ADO work item"
      }
    ],
    "workItemProvider": {
      "id": "azure-devops",
      "label": "Azure DevOps",
      "listRoute": "/api/workitems",
      "createRoute": "/api/workitems/create",
      "getRoute": "/api/workitems/:id",
      "updateStateRoute": "/api/workitems/:id/state",
      "commentRoute": "/api/workitems/:id/comments",
      "iterationsRoute": "/api/iterations",
      "teamsRoute": "/api/teams",
      "teamMembersRoute": "/api/team-members",
      "areasRoute": "/api/areas",
      "velocityRoute": "/api/velocity",
      "burndownRoute": "/api/burndown",
      "startWorkingRoute": "/api/start-working"
    },
    "mcp": {
      "tools": [
        {
          "name": "list_work_items",
          "description": "List Azure DevOps work items. Returns id, title, state, assignedTo, type, and storyPoints.",
          "route": "GET /api/workitems",
          "inputSchema": {
            "type": "object",
            "properties": {
              "iteration": {
                "type": "string",
                "description": "Iteration path."
              },
              "state": {
                "type": "string",
                "description": "Filter by state."
              },
              "refresh": {
                "type": "boolean",
                "description": "Force refresh the cache."
              }
            }
          }
        },
        {
          "name": "get_work_item",
          "description": "Get full details of a single Azure DevOps work item by id.",
          "route": "GET /api/workitems/:id",
          "inputSchema": {
            "type": "object",
            "properties": {
              "id": {
                "type": "number",
                "description": "Work item id."
              }
            },
            "required": [
              "id"
            ]
          }
        },
        {
          "name": "create_work_item",
          "description": "Create an Azure DevOps work item. Gated by permissions.",
          "route": "POST /api/workitems/create",
          "bodyFrom": "arguments",
          "inputSchema": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "User Story",
                  "Bug",
                  "Task",
                  "Feature",
                  "Epic"
                ]
              },
              "title": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "priority": {
                "type": "number",
                "enum": [
                  1,
                  2,
                  3,
                  4
                ],
                "default": 2
              },
              "storyPoints": {
                "type": "number"
              },
              "iterationPath": {
                "type": "string"
              }
            },
            "required": [
              "type",
              "title"
            ]
          }
        },
        {
          "name": "set_work_item_state",
          "description": "Change the state of a work item. Gated by permissions.",
          "route": "PATCH /api/workitems/:id/state",
          "bodyFrom": "arguments",
          "inputSchema": {
            "type": "object",
            "properties": {
              "id": {
                "type": "number"
              },
              "state": {
                "type": "string",
                "enum": [
                  "New",
                  "Active",
                  "Resolved",
                  "Closed",
                  "Removed"
                ]
              }
            },
            "required": [
              "id",
              "state"
            ]
          }
        }
      ],
      "prompts": [
        {
          "name": "standup_summary",
          "description": "Generate a daily standup summary from recent work item activity.",
          "route": "GET /api/workitems"
        },
        {
          "name": "retro_analysis",
          "description": "Generate a sprint retrospective starter from work items.",
          "route": "GET /api/workitems"
        }
      ]
    },
    "rightTabs": [
      {
        "id": "activity",
        "label": "Activity",
        "pinned": true,
        "position": 0,
        "claims": { "tabBtnId": "intelTab-activity", "panelId": "ipanel-activity" }
      },
      {
        "id": "team",
        "label": "Team",
        "pinned": true,
        "position": 1,
        "claims": { "tabBtnId": "intelTab-team", "panelId": "ipanel-team" }
      }
    ]
  }
}
